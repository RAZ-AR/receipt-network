// Beleg — data layer.
// Translated from DATA_MODEL.md. Encodes the idempotency + ledger + audit
// decisions from NON_FUNCTIONAL_REQUIREMENTS and DECISIONS (ADR-P-013 QR-first).
// This is a starting schema — review before the first migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity ----------

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

model User {
  id              String     @id @default(cuid())
  status          UserStatus @default(ACTIVE)
  phone           String?    @unique
  email           String?    @unique
  locale          String     @default("sr-Latn-RS")
  city            String?
  privacySettings Json       @default("{}")
  createdAt       DateTime   @default(now())

  profile       UserProfile?
  pointsAccount PointsAccount?
  receipts      Receipt[]
  tickets       LotteryTicket[]
  rewardClaims  RewardClaim[]
  reviews       Review[]
  notifications Notification[]
  goals         UserGoal[]
  scanSessions  ScanSession[]
}

model UserProfile {
  userId      String  @id
  user        User    @relation(fields: [userId], references: [id])
  displayName String?
  avatar      String?
  level       Int     @default(1)
  reputation  Int     @default(0)
  preferences Json    @default("{}")
}

// ---------- Business Directory ----------

enum PartnerStatus {
  NON_PARTNER
  PARTNER
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

model Business {
  id                 String             @id @default(cuid())
  legalName          String
  displayName        String
  category           String?
  partnerStatus      PartnerStatus      @default(NON_PARTNER)
  verificationStatus VerificationStatus @default(UNVERIFIED)

  locations BusinessLocation[]
  receipts  Receipt[]
  rewards   Reward[]
  reviews   Review[]
  campaigns Campaign[]
}

model BusinessLocation {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  address      String?
  coordinates  Json?
  workingHours Json?

  receipts Receipt[]
}

// ---------- Receipt ----------

enum ReceiptStatus {
  UPLOADED
  RECOGNIZED
  VERIFIED
  REJECTED
  FLAGGED
}

// ADR-P-013: QR-first verification, OCR fallback.
enum VerificationSource {
  TAXCORE_API
  OCR_FALLBACK
  MANUAL
}

model Receipt {
  id                 String              @id @default(cuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id])
  businessId         String?
  business           Business?           @relation(fields: [businessId], references: [id])
  locationId         String?
  location           BusinessLocation?   @relation(fields: [locationId], references: [id])
  originalFile       String?
  status             ReceiptStatus       @default(UPLOADED)
  purchaseDate       DateTime?
  totalAmount        Decimal?            @db.Decimal(12, 2)
  currency           String              @default("RSD")
  receiptNumber      String?
  fiscalId           String?
  // QR-first fields (see DATA_MODEL.md / ADR-P-013)
  qrRawPayload       String?
  verificationSource VerificationSource?
  verificationUrl    String?
  ocrConfidenceScore Float?
  fraudScore         Float?
  createdAt          DateTime            @default(now())

  items   ReceiptItem[]
  tickets LotteryTicket[]
  review  Review?

  // Anti-duplicate: the fiscal QR maps to one receipt globally (Fraud & Risk).
  @@unique([fiscalId, receiptNumber])
  @@index([userId])
  @@index([businessId])
}

model ReceiptItem {
  id        String   @id @default(cuid())
  receiptId String
  receipt   Receipt  @relation(fields: [receiptId], references: [id])
  name      String
  quantity  Decimal? @db.Decimal(12, 3)
  amount    Decimal? @db.Decimal(12, 2)
  category  String?
}

// ---------- Points (ledger) ----------

model PointsAccount {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id])
  balance Int    @default(0)

  transactions PointsTransaction[]
}

enum PointsTxType {
  GRANT
  REVOKE
  REDEEM
  ADJUSTMENT
}

enum PointsTxStatus {
  PENDING
  POSTED
  CANCELLED
}

// Idempotent ledger: (sourceType, sourceId) is unique so replayed
// domain events never double-post (NFR: reliability).
model PointsTransaction {
  id         String         @id @default(cuid())
  accountId  String
  account    PointsAccount  @relation(fields: [accountId], references: [id])
  type       PointsTxType
  amount     Int
  sourceType String
  sourceId   String
  status     PointsTxStatus @default(POSTED)
  createdAt  DateTime       @default(now())

  @@unique([sourceType, sourceId])
  @@index([accountId])
}

// ---------- Lottery ----------  (domain gated by Discovery — legal review)

enum LotteryStatus {
  OPEN
  LOCKED
  DRAWN
  CLOSED
}

enum TicketStatus {
  ACTIVE
  VOID
  WON
}

model Lottery {
  id           String        @id @default(cuid())
  type         String
  startAt      DateTime
  lockAt       DateTime
  drawAt       DateTime
  status       LotteryStatus @default(OPEN)
  rulesVersion String

  tickets LotteryTicket[]
}

model LotteryTicket {
  id        String       @id @default(cuid())
  lotteryId String
  lottery   Lottery      @relation(fields: [lotteryId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  receiptId String
  receipt   Receipt      @relation(fields: [receiptId], references: [id])
  status    TicketStatus @default(ACTIVE)
  issuedAt  DateTime     @default(now())

  // One ticket per eligible receipt (FR-6), idempotent issuance.
  @@unique([receiptId, lotteryId])
}

// ---------- Rewards ----------

enum RewardStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

model Reward {
  id         String       @id @default(cuid())
  businessId String?
  business   Business?    @relation(fields: [businessId], references: [id])
  title      String
  pointsCost Int
  stock      Int?
  validFrom  DateTime?
  validTo    DateTime?
  status     RewardStatus @default(ACTIVE)

  claims RewardClaim[]
  goals  UserGoal[]
}

enum ClaimStatus {
  RESERVED
  REDEEMED
  EXPIRED
  CANCELLED
}

model RewardClaim {
  id                  String      @id @default(cuid())
  rewardId            String
  reward              Reward      @relation(fields: [rewardId], references: [id])
  userId              String
  user                User        @relation(fields: [userId], references: [id])
  pointsTransactionId String?
  code                String      @unique
  status              ClaimStatus @default(RESERVED)
  expiresAt           DateTime?
}

// ---------- Goal Engine ----------

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model UserGoal {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  rewardId      String
  reward        Reward     @relation(fields: [rewardId], references: [id])
  targetPoints  Int
  currentPoints Int        @default(0)
  status        GoalStatus @default(ACTIVE)
  selectedAt    DateTime   @default(now())
  completedAt   DateTime?

  @@index([userId])
}

// ---------- Reviews ----------

enum ReviewStatus {
  PENDING
  PUBLISHED
  MODERATED
  REMOVED
}

// Tied to a verified receipt (ADR-P-004). Reward is independent of rating.
model Review {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  receiptId  String       @unique
  receipt    Receipt      @relation(fields: [receiptId], references: [id])
  businessId String
  business   Business     @relation(fields: [businessId], references: [id])
  rating     Int
  attributes Json         @default("[]")
  comment    String?
  status     ReviewStatus @default(PENDING)
}

// ---------- Daily Opportunity & Campaigns ----------

model DailyOpportunity {
  id           String    @id @default(cuid())
  businessId   String?
  campaignId   String?
  title        String
  benefitType  String
  benefitValue Json?
  startsAt     DateTime
  endsAt       DateTime
  eligibility  Json?
  limits       Json?
  status       String    @default("ACTIVE")
}

model Campaign {
  id                String    @id @default(cuid())
  businessId        String
  business          Business  @relation(fields: [businessId], references: [id])
  campaignType      String
  audience          Json?
  budget            Decimal?  @db.Decimal(12, 2)
  attributionWindow Int?
  startsAt          DateTime
  endsAt            DateTime
  status            String    @default("DRAFT")

  attributions CampaignAttribution[]
}

model CampaignAttribution {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id])
  userId          String
  receiptId       String
  attributionType String
  customerType    String
  value           Decimal? @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
}

// ---------- Notifications ----------

model Notification {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  type    String
  channel String
  payload Json   @default("{}")
  status  String @default("SCHEDULED")

  @@index([userId])
}

// ---------- Scan session (batch scanning, FR-13) ----------

model ScanSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  receiptCount Int       @default(0)
  status       String    @default("OPEN")
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
}

// ---------- Audit log (critical operations) ----------

model AuditLog {
  id         String   @id @default(cuid())
  actorType  String
  actorId    String
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}
