{
  "name": "beleg",
  "version": "0.0.0",
  "private": true,
  "description": "Beleg \u2014 universal receipt platform (Serbia). Modular monolith + Expo app.",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "pnpm --filter @beleg/api dev",
    "mobile:dev": "pnpm --filter @beleg/mobile start",
    "prisma:generate": "pnpm --filter @beleg/api exec prisma generate",
    "prisma:migrate": "pnpm --filter @beleg/api exec prisma migrate dev",
    "dev": "pnpm --parallel --filter @beleg/api --filter @beleg/mobile run dev",
    "db:start": "brew services start postgresql@16"
  },
  "engines": {
    "node": ">=20"
  }
}
