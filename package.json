{
  "name": "beleg",
  "version": "0.0.0",
  "private": true,
  "description": "Beleg — universal receipt platform (Serbia). Modular monolith + Expo app.",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "pnpm --filter @beleg/api dev",
    "mobile:dev": "pnpm --filter @beleg/mobile start",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma"
  },
  "engines": {
    "node": ">=20"
  }
}
